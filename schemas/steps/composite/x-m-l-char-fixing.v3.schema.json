{
  "$id": "x-m-l-char-fixing",
  "title": "XML Characters Fixing",
  "type": "object",
  "description": "Fixes invalid characters in XML documents. Expects: raw document. Sends back: raw document.",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlcharfixing.XMLCharFixingStep",
    "parameterMappings": [
      "OUTPUT_URI",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "properties": {
    "replacement": {
      "type": "string",
      "default": "_#x%X;",
      "title": "Replacement string",
      "description": "Enter a Java-formatted replacement string.",
      "x-editor": {
        "widget": "text",
        "layout": {
          "vertical": true
        },
        "text": {
          "allowEmpty": true
        }
      }
    }
  }
}