{
  "$id": "cleanup",
  "title": "Cleanup",
  "type": "object",
  "description": "Cleans strings by normalizing quotes, punctuation, etc. ready for further processing. Expects: filter events. Sends back: filter events.",
  "x-step": {
    "class": "net.sf.okapi.steps.cleanup.CleanupStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "normalizeQuotes": {
      "type": "boolean",
      "default": true,
      "title": "Normalize quotation marks",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "checkCharacters": {
      "type": "boolean",
      "default": true,
      "title": "Check for corrupt or unexpected characters",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "matchRegexExpressions": {
      "type": "boolean",
      "default": true,
      "title": "Mark segments matching default regular expressions for removal",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "matchUserRegex": {
      "type": "boolean",
      "default": true,
      "title": "Mark segments matching user defined regular expressions for removal",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "userRegex": {
      "type": "string",
      "default": "",
      "title": "User defined regex string",
      "x-editor": {
        "widget": "text",
        "layout": {
          "vertical": true
        },
        "text": {
          "allowEmpty": true
        }
      }
    },
    "pruneTextUnit": {
      "type": "boolean",
      "default": true,
      "title": "Remove unnecessary segments from text unit",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "normalizePunctuations": {
      "type": "boolean",
      "default": false,
      "title": "Standardize spaces before and after certain punctuation marks to English writing style.",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "keepCrNlIntact": {
      "type": "boolean",
      "default": false,
      "title": "Keep CR and NL characters intact. They are not normalized to an ASCII space with spaces and tabs.",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    }
  }
}