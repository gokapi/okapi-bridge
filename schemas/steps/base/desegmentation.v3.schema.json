{
  "$id": "desegmentation",
  "title": "Desegmentation",
  "type": "object",
  "description": "Joins all segments into a single content. Expects: filter events. Sends back: filter events.",
  "x-step": {
    "class": "net.sf.okapi.steps.desegmentation.DesegmentationStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE",
      "TARGET_LOCALES"
    ],
    "eventHandlers": [
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "desegmentSource": {
      "type": "boolean",
      "default": true,
      "title": "Join all segments of the source text",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "desegmentTarget": {
      "type": "boolean",
      "default": true,
      "title": "Join all segments of the target text",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "renumberCodes": {
      "type": "boolean",
      "default": false,
      "title": "Restore original IDs to renumbered codes",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    }
  }
}