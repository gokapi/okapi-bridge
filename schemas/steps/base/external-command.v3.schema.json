{
  "$id": "external-command",
  "title": "External Command",
  "type": "object",
  "description": "Execute an external command line.",
  "x-step": {
    "class": "net.sf.okapi.steps.externalcommand.ExternalCommandStep",
    "parameterMappings": [
      "OUTPUT_URI",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "properties": {
    "command": {
      "type": "string",
      "default": "",
      "title": "Command line",
      "description": "Command path to execute",
      "x-editor": {
        "widget": "text",
        "layout": {
          "vertical": true
        }
      }
    },
    "timeout": {
      "type": "integer",
      "default": -1,
      "title": "Timeout",
      "description": "Timeout in seconds after which the command is cancelled (use -1 for no timeout)",
      "x-editor": {
        "widget": "text"
      }
    }
  }
}