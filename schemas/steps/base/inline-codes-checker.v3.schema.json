{
  "$id": "inline-codes-checker",
  "title": "Inline Codes Quality Check",
  "type": "object",
  "description": "Compare source and target for inline code differences. Expects: filter events. Sends back: filter events.",
  "x-step": {
    "class": "net.sf.okapi.steps.inlinescodeschecker.InlineCodesCheckerStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "codeDifference": {
      "type": "boolean",
      "default": true
    },
    "guessOpenClose": {
      "type": "boolean",
      "default": true
    },
    "extraCodesAllowed": {
      "type": "boolean",
      "default": false
    },
    "missingCodesAllowed": {
      "type": "boolean",
      "default": false
    },
    "typesToIgnore": {
      "type": "string",
      "default": "mrk;x-df-s;"
    }
  }
}