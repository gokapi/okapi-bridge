{
  "$id": "xliff-joiner",
  "title": "XLIFF Joiner",
  "type": "object",
  "description": "Join multiple XLIFF documents into one. Expects: raw document. Sends back: raw document.",
  "x-step": {
    "class": "net.sf.okapi.steps.xliffsplitter.XliffJoinerStep",
    "parameterMappings": [
      "OUTPUT_URI",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "properties": {
    "inputFileMarker": {
      "type": "string",
      "default": "_PART",
      "title": "Input file marker",
      "x-editor": {
        "widget": "text"
      }
    },
    "outputFileMarker": {
      "type": "string",
      "default": "_CONCAT",
      "title": "Output file marker",
      "x-editor": {
        "widget": "text",
        "text": {
          "allowEmpty": true
        }
      }
    }
  }
}