{
  "$id": "patterns-checker",
  "title": "Pattern (regex) Quality Check",
  "type": "object",
  "description": "Compare source and target for pattern differences. Expects: filter events. Sends back: filter events.",
  "x-step": {
    "class": "net.sf.okapi.steps.patternschecker.PatternsCheckerStep",
    "parameterMappings": [
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "checkPatterns": {
      "type": "boolean",
      "default": true
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "fromSource": {
            "type": "boolean"
          },
          "single": {
            "type": "boolean"
          },
          "severity": {
            "type": "integer"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "description": "Array of patterns encoded from indexed flat parameters."
    }
  }
}