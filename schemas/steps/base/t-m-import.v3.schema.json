{
  "$id": "t-m-import",
  "title": "TM Import",
  "type": "object",
  "description": "Import text into a new or existing Pensieve TM. Expects: filter events. Sends back: filter events.",
  "x-step": {
    "class": "net.sf.okapi.steps.tmimport.TMImportStep",
    "parameterMappings": [
      "ROOT_DIRECTORY",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "properties": {
    "tmDirectory": {
      "type": "string",
      "default": "",
      "title": "Directory of the TM where to import",
      "description": "Full path of directory of the TM where to import",
      "x-editor": {
        "widget": "folder",
        "layout": {
          "vertical": true
        },
        "folder": {
          "browseTitle": "TM Directory"
        }
      }
    },
    "overwriteSameSource": {
      "type": "boolean",
      "default": false,
      "title": "Overwrite if source is the same",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    }
  }
}