{
  "$id": "xliff-splitter",
  "title": "XLIFF Splitter",
  "type": "object",
  "description": "Split an XLIFF document into separate files for each <file> element. Expects: raw document. Sends back: raw document.",
  "x-step": {
    "class": "net.sf.okapi.steps.xliffsplitter.XliffSplitterStep",
    "parameterMappings": [
      "OUTPUT_URI",
      "SOURCE_LOCALE",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch",
      "handleStartBatchItem"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "properties": {
    "translation_type": {
      "type": "boolean",
      "default": false
    },
    "translation_status": {
      "type": "boolean",
      "default": false
    },
    "bigFile": {
      "type": "boolean",
      "default": false,
      "title": "Process big file",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "fileMarker": {
      "type": "string",
      "default": "_PART",
      "title": "File marker",
      "x-editor": {
        "widget": "text",
        "enabledBy": {
          "parameter": "bigFile",
          "enabledWhenSelected": true
        }
      }
    },
    "updateSDLTranslationStatus": {
      "type": "boolean",
      "default": false,
      "title": "Update the <iws:status> translation status (WorldServer-specific)",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "translationTypeValue": {
      "type": "string",
      "default": "manual_translation",
      "title": "Value for 'translation_type'",
      "description": "Value to set for the translation_type attribute.",
      "x-editor": {
        "widget": "text",
        "enabledBy": {
          "parameter": "updateSDLTranslationStatus",
          "enabledWhenSelected": true
        }
      }
    },
    "translationStatusValue": {
      "type": "string",
      "default": "finished",
      "title": "Value for 'translation_status'",
      "description": "Value to set for the translation_status attribute.",
      "x-editor": {
        "widget": "text",
        "enabledBy": {
          "parameter": "updateSDLTranslationStatus",
          "enabledWhenSelected": true
        }
      }
    },
    "restoreOriginalNames": {
      "type": "boolean",
      "default": false,
      "title": "Restore original file names",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    }
  }
}