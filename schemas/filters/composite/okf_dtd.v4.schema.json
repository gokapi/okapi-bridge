{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_dtd.v4.schema.json",
  "version": 4,
  "title": "DTD Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_dtd",
    "class": "net.sf.okapi.filters.dtd.DTDFilter",
    "extensions": [
      ".dtd",
      ".ent"
    ],
    "mimeTypes": [
      "application/xml+dtd"
    ],
    "configurations": [
      {
        "configId": "okf_dtd",
        "name": "DTD (Document Type Definition)",
        "description": "Configuration for XML DTD documents (entities content)",
        "mimeType": "application/xml+dtd",
        "extensions": ".dtd;.ent;",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.dtd.DTDFilter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "useCodeFinder": {
      "type": "boolean",
      "default": true,
      "title": "Use Code Finder",
      "description": "Enable regular expression-based inline code detection in extracted text."
    },
    "simplifierRules": {
      "type": "string",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor",
      "title": "Simplifier Rules"
    }
  },
  "additionalProperties": false,
  "x-kind": "OkfDtdFilterConfig",
  "x-apiVersion": "v4",
  "x-baseVersion": 4,
  "x-introducedInOkapi": "1.47.0",
