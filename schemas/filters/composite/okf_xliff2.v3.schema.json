{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neokapi.github.io/schemas/filters/okf_xliff2.v3.schema.json",
  "version": 3,
  "title": "XLIFF-2 Filter",
  "type": "object",
  "x-filter": {
    "id": "okf_xliff2",
    "class": "net.sf.okapi.filters.xliff2.XLIFF2Filter",
    "extensions": [
      ".xlf",
      ".xliff",
      ".xlf2",
      ".xliff2"
    ],
    "mimeTypes": [
      "application/xliff+xml"
    ],
    "configurations": [
      {
        "configId": "okf_xliff2",
        "name": "XLIFF-2",
        "description": "Configuration for XLIFF-2 documents.",
        "mimeType": "application/xliff+xml",
        "extensions": ".xlf;.xliff;.xlf2;.xliff2",
        "isDefault": true,
        "filterClass": "net.sf.okapi.filters.xliff2.XLIFF2Filter"
      }
    ],
    "serializationFormat": "stringParameters"
  },
  "properties": {
    "inlineCodes": {
      "$ref": "#/$defs/inlineCodes",
      "title": "Inline Codes",
      "description": "Pattern-based detection of inline codes (placeholders, variables, tags) within translatable text."
    },
    "extraction": {
      "type": "object",
      "title": "Control what content is extracted",
      "properties": {
        "needsSegmentation": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "needsSegmentation",
          "description": "Resegment units marked with canSegment=\"yes\" that do not already have a target.",
          "title": "Needs Segmentation"
        },
        "forceUniqueIds": {
          "type": "boolean",
          "default": false,
          "title": "Ensure tag IDs are unique within units",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "forceUniqueIds",
          "description": "Force unique text unit IDs"
        },
        "simplifyTags": {
          "type": "boolean",
          "default": false,
          "x-flattenPath": "simplifyTags",
          "description": "Simplify inline tags"
        },
        "ignoreTagTypeMatch": {
          "type": "boolean",
          "default": false,
          "title": "Ignore tag type mismatch between source and target",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "ignoreTagTypeMatch",
          "description": "Ignore tag type matching"
        }
      }
    },
    "states": {
      "type": "object",
      "title": "Translation state handling",
      "properties": {
        "discardInvalidTargets": {
          "type": "boolean",
          "default": false,
          "title": "Discard invalid targets rather than rejecting the file",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "discardInvalidTargets",
          "description": "Discard invalid target elements"
        },
        "subfilterOverwriteTarget": {
          "type": "boolean",
          "default": false,
          "title": "Subfilter: Always Overwrite Target?",
          "description": "Sub-filter overwrites target",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "subfilterOverwriteTarget"
        }
      }
    },
    "output": {
      "type": "object",
      "title": "Output settings",
      "properties": {
        "writeOriginalData": {
          "type": "boolean",
          "default": true,
          "title": "Output includes original data when available",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "writeOriginalData",
          "description": "Write original data to output"
        },
        "maxValidation": {
          "type": "boolean",
          "default": true,
          "title": "Maximum Validation",
          "x-editor": {
            "widget": "checkbox",
            "layout": {
              "vertical": true
            }
          },
          "x-flattenPath": "maxValidation",
          "description": "Perform maximum validation of the XLIFF 2.x format when parsing."
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "inlineCodes": {
      "type": "object",
      "title": "Inline Codes",
      "description": "Inline code detection and handling",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "title": "Enable Inline Code Detection",
          "description": "Enable pattern-based detection of inline codes (placeholders, tags, etc.)",
          "x-flattenPath": "useCodeFinder"
        },
        "rules": {
          "$ref": "#/$defs/codeFinderRules",
          "title": "Code Finder Rules",
          "x-flattenPath": "codeFinderRules",
          "description": "Regex patterns to identify inline codes in translatable text",
          "x-editor": {
            "widget": "codeFinderRules"
          }
        },
        "mergeAdjacent": {
          "type": "boolean",
          "title": "Merge Adjacent Codes",
          "description": "Merge consecutive inline codes into a single placeholder",
          "x-flattenPath": "mergeAdjacentCodes"
        },
        "moveBoundaryCodes": {
          "type": "boolean",
          "title": "Move Boundary Codes",
          "description": "Move inline codes at segment boundaries to the skeleton (non-translatable)",
          "x-flattenPath": "moveLeadingAndTrailingCodesToSkeleton"
        },
        "simplifierRules": {
          "$ref": "#/$defs/simplifierRules",
          "title": "Simplifier Rules",
          "x-flattenPath": "simplifierRules",
          "description": "Rules for simplifying inline code representation"
        }
      }
    },
    "codeFinderRules": {
      "type": "object",
      "title": "Code Finder Rules",
      "description": "Regex patterns for inline code detection",
      "properties": {
        "rules": {
          "type": "array",
          "title": "Patterns",
          "description": "List of regex patterns to detect inline codes",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "title": "Pattern",
                "description": "Regex pattern for inline code detection"
              }
            },
            "required": [
              "pattern"
            ]
          }
        },
        "sample": {
          "type": "string",
          "title": "Sample Text",
          "description": "Sample text to test patterns against"
        },
        "useAllRulesWhenTesting": {
          "type": "boolean",
          "default": true,
          "title": "Test All Rules Together",
          "description": "Test all rules together or individually"
        }
      },
      "x-okapiFormat": "inlineCodeFinder"
    },
    "simplifierRules": {
      "type": "string",
      "title": "Simplifier Rules",
      "description": "Rules for simplifying inline code representation",
      "x-widget": "simplifierRulesEditor"
    }
  },
  "x-kind": "OkfXliff2FilterConfig",
  "x-apiVersion": "v3",
  "x-baseVersion": 17,
  "x-introducedInOkapi": "1.47.0",
  "x-baseHash": "ac7131c296f2",
  "x-compositeHash": "9ad1edf2a22e"
}
