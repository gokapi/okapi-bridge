{
  "$id": "x-m-l-validation",
  "title": "XML Validation",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlvalidation.XMLValidationStep",
    "parameterMappings": [],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "x-m-l-validation",
    "type": "step",
    "displayName": "XML Validation",
    "description": "Validate XML documents. Expects: raw XML document. Sends back: raw XML document.",
    "category": "pipeline"
  },
  "properties": {
    "validationType": {
      "type": "integer",
      "default": 0,
      "title": "Type of validation",
      "description": "Indicates which validation to use",
      "enum": [
        "0",
        "1",
        "2"
      ],
      "x-enumLabels": [
        "DTD",
        "XML Schema",
        "RelaxNG Schema"
      ],
      "x-editor": {
        "widget": "select",
        "enabledBy": {
          "parameter": "validate",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        }
      }
    },
    "useFoundDTD": {
      "type": "boolean",
      "default": true,
      "title": "Use DTD declarations found in the input documents",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "validate": {
      "type": "boolean",
      "default": false,
      "title": "Validate the documents structure [Well-formedness is always checked]",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "schemaPath": {
      "type": "string",
      "default": "",
      "title": "Path of the XML Schema",
      "description": "Full path of the XML Schema.",
      "x-editor": {
        "widget": "path",
        "enabledBy": {
          "parameter": "validate",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        },
        "path": {
          "browseTitle": "Schema",
          "allowEmpty": true,
          "filters": [
            {
              "name": "Schema Files (*.xsd)",
              "extensions": "*.xsd"
            },
            {
              "name": "All Files (*.*)",
              "extensions": "*.*"
            }
          ]
        }
      }
    }
  }
}