{
  "$id": "x-m-l-analysis",
  "title": "XML Analysis",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.xmlanalysis.XMLAnalysisStep",
    "parameterMappings": [],
    "eventHandlers": [
      "handleEndBatch",
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "x-m-l-analysis",
    "type": "step",
    "displayName": "XML Analysis",
    "description": "Generate an analysis report of a set of XML documents. Expects: raw document. Sends back: raw document.",
    "category": "pipeline",
    "tags": [
      "analysis"
    ]
  },
  "properties": {
    "outputPath": {
      "type": "string",
      "default": "analysis.html",
      "title": "Path of the result file",
      "description": "Full path of the result file.",
      "x-editor": {
        "widget": "path",
        "layout": {
          "vertical": true
        },
        "path": {
          "browseTitle": "Result File",
          "forSaveAs": true,
          "filters": [
            {
              "name": "Text Files (*.txt)",
              "extensions": "*.txt"
            },
            {
              "name": "All Files (*.*)",
              "extensions": "*.*"
            }
          ]
        }
      }
    },
    "autoOpen": {
      "type": "boolean",
      "default": true,
      "title": "Open the result file after completion",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    }
  }
}