{
  "$id": "okapi:characters-checker",
  "title": "Characters Quality Check",
  "type": "object",
  "x-component": {
    "id": "okapi:characters-checker",
    "type": "step",
    "displayName": "Characters Quality Check",
    "description": "Compare source and target for character inconsistencies. Expects: filter events. Sends back: filter events."
  },
  "properties": {
    "corruptedCharacters": {
      "type": "boolean",
      "default": true
    },
    "checkAllowedCharacters": {
      "type": "boolean",
      "default": true
    },
    "checkCharacters": {
      "type": "boolean",
      "default": false
    },
    "charset": {
      "type": "string",
      "default": "ISO-8859-1"
    },
    "extraCharsAllowed": {
      "type": "string",
      "default": ""
    }
  }
}