{
  "$id": "okapi:encoding-conversion",
  "title": "Encoding Conversion",
  "type": "object",
  "x-component": {
    "id": "okapi:encoding-conversion",
    "type": "step",
    "displayName": "Encoding Conversion",
    "description": "Convert the character set encoding of a text-based file. Expects: raw document. Sends back: raw document."
  },
  "properties": {
    "unescapeNCR": {
      "type": "boolean",
      "default": true
    },
    "unescapeCER": {
      "type": "boolean",
      "default": true
    },
    "unescapeJava": {
      "type": "boolean",
      "default": true
    },
    "escapeAll": {
      "type": "boolean",
      "default": false
    },
    "escapeNotation": {
      "type": "integer",
      "default": 0
    },
    "userFormat": {
      "type": "string",
      "default": "%d"
    },
    "useBytes": {
      "type": "boolean",
      "default": false
    },
    "BOMonUTF8": {
      "type": "boolean",
      "default": true
    },
    "reportUnsupported": {
      "type": "boolean",
      "default": true
    }
  }
}