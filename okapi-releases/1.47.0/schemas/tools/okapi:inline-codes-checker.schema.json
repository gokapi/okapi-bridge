      "type": "boolean",
      "default": true
    },
    "guessOpenClose": {
      "type": "boolean",
      "default": true
    },
    "typesToIgnore": {
      "type": "string",
      "default": "mrk;x-df-s;"
    },
    "extraCodesAllowed": {
      "type": "integer",
      "default": 0
    },
    "missingCodesAllowed": {
      "type": "integer",
      "default": 0
    }
  }
}