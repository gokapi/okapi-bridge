      "default": ""
    },
    "packageName": {
      "type": "string",
      "default": "pack1"
    },
    "packageDirectory": {
      "type": "string",
      "default": "${inputRootDir}"
    },
    "message": {
      "type": "string",
      "default": ""
    },
    "outputManifest": {
      "type": "boolean",
      "default": true
    },
    "createZip": {
      "type": "boolean",
      "default": false
