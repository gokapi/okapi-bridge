{
  "$id": "inconsistency-check",
  "title": "Inconsistency Check",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.inconsistencycheck.InconsistencyCheckStep",
    "parameterMappings": [
      "INPUT_ROOT_DIRECTORY",
      "ROOT_DIRECTORY",
      "TARGET_LOCALE"
    ],
    "eventHandlers": [
      "handleEndBatch",
      "handleEndDocument",
      "handleStartBatch",
      "handleStartDocument",
      "handleStartSubDocument",
      "handleTextUnit"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "filter-events"
  },
  "x-component": {
    "id": "inconsistency-check",
    "type": "step",
    "displayName": "Inconsistency Check",
    "description": "Checks for source entries that are the same but have different translations or target entries that are the same but have different sources. Expects: filter events. Sends back: filter events.",
    "category": "translate",
    "inputs": [
      "block"
    ],
    "tags": [
      "translation",
      "quality"
    ],
    "requires": [
      "target-language"
    ]
  },
  "properties": {
    "checkInconststencies": {
      "type": "boolean",
      "default": true,
      "title": "Check inconsistencies",
      "x-editor": {
        "widget": "checkbox",
        "layout": {
          "vertical": true
        }
      }
    },
    "checkPerFile": {
      "type": "boolean",
      "default": false,
      "title": "Check for inconsistencies on a file-by-file basis",
      "x-editor": {
        "widget": "checkbox",
        "enabledBy": {
          "parameter": "checkInconststencies",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        }
      }
    },
    "outputPath": {
      "type": "string",
      "default": "${rootDir}/inconsistency-report.xml",
      "title": "Path of the report file:",
      "x-editor": {
        "widget": "path",
        "enabledBy": {
          "parameter": "checkInconststencies",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        },
        "path": {
          "browseTitle": "Inconsistency Report File",
          "forSaveAs": true,
          "filters": [
            {
              "name": "All Files (*.*)",
              "extensions": "*.*"
            }
          ]
        }
      }
    },
    "displayOption": {
      "type": "string",
      "default": "generic",
      "title": "Representation of the inline codes in the report",
      "enum": [
        "original",
        "generic",
        "plain"
      ],
      "x-enumLabels": [
        "Original codes",
        "Generic markers",
        "Plain text"
      ],
      "x-editor": {
        "widget": "dropdown",
        "enabledBy": {
          "parameter": "checkInconststencies",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        }
      }
    },
    "autoOpen": {
      "type": "boolean",
      "default": true,
      "title": "Open the report file after completion",
      "x-editor": {
        "widget": "checkbox",
        "enabledBy": {
          "parameter": "checkInconststencies",
          "enabledWhenSelected": true
        },
        "layout": {
          "vertical": true
        }
      }
    },
    "original": {
      "type": "boolean",
      "default": false
    },
    "generic": {
      "type": "boolean",
      "default": false
    },
    "plain": {
      "type": "boolean",
      "default": false
    }
  }
}