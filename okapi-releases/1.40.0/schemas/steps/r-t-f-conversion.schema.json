    "category": "transform",
    "outputs": [
      "data"
    ],
    "tags": [
      "text-processing"
    ]
  },
  "properties": {
    "bomOnUTF8": {
      "type": "boolean",
      "default": true,
      "title": "Use Byte-Order-Mark for UTF-8 output"
    },
    "lineBreak": {
      "type": "string",
      "default": "$0a$",
      "description": "Select the type of line-break to use in the output.",
      "title": "Type of line-break to use"
    },
    "updateEncoding": {
      "type": "boolean",
      "default": true,
      "title": "Try to update the encoding declarations (when detected)"
    }
  }
}