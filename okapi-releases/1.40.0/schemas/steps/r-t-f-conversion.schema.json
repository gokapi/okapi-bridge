{
  "$id": "r-t-f-conversion",
  "title": "RTF Conversion",
  "type": "object",
  "x-step": {
    "class": "net.sf.okapi.steps.rtfconversion.RTFConversionStep",
    "parameterMappings": [
      "OUTPUT_ENCODING",
      "OUTPUT_URI"
    ],
    "eventHandlers": [
      "handleRawDocument",
      "handleStartBatch"
    ],
    "interfaces": [],
    "inputType": "filter-events",
    "outputType": "file"
  },
  "x-component": {
    "id": "r-t-f-conversion",
    "type": "step",
    "displayName": "RTF Conversion",
